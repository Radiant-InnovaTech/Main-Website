# ─────────────────────────────────────────────────────────────
#  Radiant Nexus Backend — Environment Variables
#  Copy this file to .env and fill in all values before running.
#  NEVER commit the actual .env file to git.
# ─────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────
# Port the Node.js server listens on (Nginx proxies from 80/443 → this port)
PORT=3000

# production | development
NODE_ENV=production

# ── Security ─────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# IMPORTANT: Must be a long random string. Keep secret.
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_STRING_64_CHARS_MINIMUM

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://radiantinnovatech.com,https://www.radiantinnovatech.com

# ── Brevo SMTP (Email) ────────────────────────────────────────
# How to get these:
#   1. Log in to app.brevo.com
#   2. Go to SMTP & API → SMTP
#   3. Your SMTP login = your Brevo account email
#   4. Your SMTP password = the key shown on that page (starts with "xsmtp")
#
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-brevo-login@example.com
SMTP_PASS=xsmtp-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SMTP_FROM=waitlist@radiantinnovatech.com
